{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile with branch and batch information.",
      "properties": {
        "id": { "type": "string" },
        "externalAuthId": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "professor", "non-teaching-staff"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "branch": { "type": "string" },
        "batch": { "type": "string" },
        "university": { "type": "string" },
        "college": { "type": "string" },
        "feedbackRating": { "type": "number" },
        "feedbackCount": { "type": "number" },
        "totalFeedbackPoints": { "type": "number" },
        "isVisibleInDirectory": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "deactivated"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "externalAuthId", "role", "name", "email", "isVisibleInDirectory", "createdAt", "updatedAt"]
    },
    "Friendship": {
      "title": "Friendship",
      "type": "object",
      "description": "Represents a connection between two alumni.",
      "properties": {
        "id": { "type": "string" },
        "uids": { "type": "array", "items": { "type": "string" } },
        "followedBy": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "mutual"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uids", "followedBy", "status", "updatedAt"]
    },
    "FeedPost": {
      "title": "FeedPost",
      "type": "object",
      "description": "A social post in the alumni feed.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorId", "content", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "User notification for events, connections, or general updates.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["connection", "event", "general"] },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "message", "read", "createdAt"]
    },
    "JobPosting": {
      "title": "JobPosting",
      "type": "object",
      "description": "A career opportunity shared by an alumnus.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "posterId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "company", "posterId", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "friendships/{friendshipId}",
        "definition": {
          "entityName": "Friendship",
          "schema": { "$ref": "#/backend/entities/Friendship" },
          "description": "Tracks connections between users."
        }
      },
      {
        "path": "feed/{postId}",
        "definition": {
          "entityName": "FeedPost",
          "schema": { "$ref": "#/backend/entities/FeedPost" },
          "description": "Social posts for the community feed."
        }
      },
      {
        "path": "notifications/{notificationId}",
        "definition": {
          "entityName": "Notification",
          "schema": { "$ref": "#/backend/entities/Notification" },
          "description": "In-app notifications."
        }
      },
      {
        "path": "jobPostings/{jobId}",
        "definition": {
          "entityName": "JobPosting",
          "schema": { "$ref": "#/backend/entities/JobPosting" },
          "description": "Alumni career opportunities."
        }
      }
    ]
  }
}