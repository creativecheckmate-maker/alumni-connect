
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile with branch and batch information.",
      "properties": {
        "id": { "type": "string" },
        "externalAuthId": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "professor", "non-teaching-staff"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "branch": { "type": "string", "description": "Academic branch (e.g. CSE, ME)" },
        "batch": { "type": "string", "description": "Graduation year or batch name" },
        "university": { "type": "string" },
        "college": { "type": "string" },
        "feedbackRating": { "type": "number" },
        "feedbackCount": { "type": "number" },
        "totalFeedbackPoints": { "type": "number" },
        "isVisibleInDirectory": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "deactivated"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "externalAuthId", "role", "name", "email", "isVisibleInDirectory", "createdAt", "updatedAt"]
    },
    "Friendship": {
      "title": "Friendship",
      "type": "object",
      "description": "Represents a connection between two alumni.",
      "properties": {
        "id": { "type": "string" },
        "uids": { "type": "array", "items": { "type": "string" } },
        "followedBy": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "mutual"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uids", "followedBy", "status", "updatedAt"]
    },
    "FeedPost": {
      "title": "FeedPost",
      "type": "object",
      "description": "A social post in the alumni feed.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorId", "content", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "User notification for events, connections, or general updates.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["connection", "event", "general"] },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "message", "read", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "A private message between two users.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "chatId": { "type": "string", "description": "Unique ID for the conversation (e.g. uid1_uid2)" },
        "text": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "delivered", "seen"], "description": "Status of the message for delivery feedback." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "receiverId", "participants", "chatId", "text", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "friendships/{friendshipId}",
        "definition": {
          "entityName": "Friendship",
          "schema": { "$ref": "#/backend/entities/Friendship" },
          "description": "Tracks mutual follows between users."
        }
      },
      {
        "path": "feed/{postId}",
        "definition": {
          "entityName": "FeedPost",
          "schema": { "$ref": "#/backend/entities/FeedPost" },
          "description": "Social posts for the community feed."
        }
      },
      {
        "path": "notifications/{notificationId}",
        "definition": {
          "entityName": "Notification",
          "schema": { "$ref": "#/backend/entities/Notification" },
          "description": "In-app notifications."
        }
      },
      {
        "path": "messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Private messages between users."
        }
      }
    ]
  }
}
