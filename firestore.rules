rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'creativecheckmate@gmail.com' ||
        request.auth.uid == 'XuRuoj1HWaS5nIiVZVoEdbaGX052'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /friendships/{friendshipId} {
      // Use consolidated 'read' to authorize listing via frontend filters
      allow read: if isSignedIn() && (request.auth.uid in resource.data.uids || isAdmin());
      allow write: if isSignedIn();
    }

    match /messages/{messageId} {
      // Participants can read their own messages. Filters are applied on the frontend.
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
    }

    match /notifications/{notificationId} {
      // Users can only read their own notifications.
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn();
    }

    match /feed/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    match /jobPostings/{jobId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.posterId == request.auth.uid);
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}