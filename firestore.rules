rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. ADMIN LOGIC: Absolute access for management accounts.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "creativecheckmate@gmail.com" ||
        request.auth.token.email == "geminiak8@gmail.com" ||
        request.auth.uid == "XuRuoj1HWaS5nIiVZVoEdbaGX052" ||
        request.auth.uid == "zEyeEyDugUWHv4RYKvgntWLunXH2"
      );
    }

    // 2. GLOBAL BYPASS: High-priority match for Admin troubleshooting.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 3. USERS: Allows authenticated 'list' and 'get' for the Directory and Leaderboard.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 4. NOTIFICATIONS: Restricted to recipient or admin.
    match /notifications/{notificationId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    // 5. FRIENDSHIPS: Secure connection tracking.
    match /friendships/{friendshipId} {
      allow read: if request.auth != null && (resource == null || request.auth.uid in resource.data.uids || isAdmin());
      allow write: if request.auth != null;
    }

    // 6. SOCIAL FEED: Community updates.
    match /feed/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource == null || resource.data.authorId == request.auth.uid || isAdmin());
    }

    // 7. CAREERS: Job board access.
    match /jobPostings/{jobId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource == null || resource.data.posterId == request.auth.uid || isAdmin());
    }

    // 8. INFRASTRUCTURE: Public site content and event listings.
    match /siteContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /events/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Deployment Sync Trigger: 2024-05-20T14:30:00Z
  }
}