rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'creativecheckmate@gmail.com' ||
        request.auth.token.email == 'geminiak8@gmail.com' ||
        request.auth.uid == 'XuRuoj1HWaS5nIiVZVoEdbaGX052' ||
        request.auth.uid == 'zEyeEyDugUWHv4RYKvgntWLunXH2'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /friendships/{friendshipId} {
      // Allow participants to see their connection status
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.uids || friendshipId.split('_').hasAny([request.auth.uid]));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.uids);
      allow delete: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.uids || friendshipId.split('_').hasAny([request.auth.uid])));
    }

    match /messages/{messageId} {
      // Allow participants to read conversation history
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants || messageId.split('_').hasAny([request.auth.uid]));
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update, delete: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.participants));
    }

    match /notifications/{notificationId} {
      // Allow users to see their own notifications
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /feed/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    match /jobPostings/{jobId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.posterId == request.auth.uid);
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}