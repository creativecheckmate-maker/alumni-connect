
/**
 * @file firestore.rules
 * @description Security rules for the Nexus Alumni Firestore database.
 *
 * @version 2
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth.token.email == 'creativecheckmate@gmail.com';
    }

    function isStudent() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || resource.data.isVisibleInDirectory == true || isAdmin();
      allow list: if true;
      allow create: if isOwner(userId) && request.resource.data.externalAuthId == userId;
      // Allow students to update feedback fields for professors and staff
      allow update: if (isExistingOwner(userId) && request.resource.data.externalAuthId == resource.data.externalAuthId) 
                    || isAdmin()
                    || (isStudent() && resource.data.role in ['professor', 'non-teaching-staff'] && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feedbackRating', 'feedbackCount', 'totalFeedbackPoints', 'updatedAt']));
      allow delete: if isOwner(userId) || isAdmin();
    }

    function isExistingOwner(ownerId) {
      return isOwner(ownerId) && resource != null;
    }

    function isCreator(ownerField) {
      return isSignedIn() && request.resource.data[ownerField] == request.auth.uid;
    }

    function isParticipant(mentorId, menteeId) {
      return isSignedIn() && (request.auth.uid == mentorId || request.auth.uid == menteeId);
    }

    function isExistingParticipant(mentorId, menteeId) {
      return isParticipant(mentorId, menteeId) && resource != null;
    }

    match /events/{eventId} {
      allow get, list: if isSignedIn();
      allow create: if isCreator('organizerId') || isAdmin();
      allow update, delete: if isExistingOwner(resource.data.organizerId) || isAdmin();
    }

    match /jobPostings/{jobPostingId} {
      allow get, list: if isSignedIn();
      allow create: if isCreator('posterId') || isAdmin();
      allow update, delete: if isExistingOwner(resource.data.posterId) || isAdmin();
    }

    match /mentorshipConnections/{connectionId} {
      allow get: if isParticipant(resource.data.mentorId, resource.data.menteeId) || isAdmin();
      allow list: if isSignedIn();
      allow create: if isParticipant(request.resource.data.mentorId, request.resource.data.menteeId) || isAdmin();
      allow update, delete: if isExistingParticipant(resource.data.mentorId, resource.data.menteeId) || isAdmin();
    }
  }
}
