rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'creativecheckmate@gmail.com' ||
        request.auth.uid == 'XuRuoj1HWaS5nIiVZVoEdbaGX052'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /friendships/{friendshipId} {
      // Allow list for any signed-in user to support filtered queries
      allow get: if isSignedIn() && (request.auth.uid in resource.data.uids || isAdmin());
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      // Allow participants to manage their relationships
      allow update, delete: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.uids));
    }

    match /messages/{messageId} {
      // Trust mandatory participant filters for list operations
      allow get: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update, delete: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.participants));
    }

    match /notifications/{notificationId} {
      // Trust mandatory user ID filters for list operations
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /feed/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    match /jobPostings/{jobId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.posterId == request.auth.uid);
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}