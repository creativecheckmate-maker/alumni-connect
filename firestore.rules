rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. ADMIN BYPASS: Absolute access for testing accounts.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "creativecheckmate@gmail.com" ||
        request.auth.uid == "XuRuoj1HWaS5nIiVZVoEdbaGX052"
      );
    }

    // 2. UNIVERSAL UNBLOCK: Allows authenticated users to interact with platform core.
    // Explicitly unblocks 'list' and 'get' operations for all community collections.
    match /{document=**} {
      allow read, write: if request.auth != null || isAdmin();
    }

    // 3. VOICE CHAT SIGNALING: Authorized signaling for peer-to-peer WebRTC audio.
    match /calls/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in chatId.split('_');
      
      match /offerCandidates/{candidateId} {
        allow read, write: if request.auth != null;
      }
      match /answerCandidates/{candidateId} {
        allow read, write: if request.auth != null;
      }
    }

    // Deployment Trigger: 2024-05-22T12:00:00Z - Enhanced Voice Signaling HUD Authorization.
  }
}