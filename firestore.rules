rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'creativecheckmate@gmail.com' ||
        request.auth.uid == 'XuRuoj1HWaS5nIiVZVoEdbaGX052'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /friendships/{friendshipId} {
      // Allow reading friendships if the user is signed in.
      // Privacy is enforced by mandatory frontend filters: .where('uids', 'array-contains', uid)
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid in resource.data.uids || isAdmin());
    }

    match /messages/{messageId} {
      // Allow reading messages if the user is signed in.
      // Privacy is enforced by mandatory frontend filters: .where('participants', 'array-contains', uid)
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
    }

    match /notifications/{notificationId} {
      // Users can read/write their own notifications
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /feed/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    match /jobPostings/{jobId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.posterId == request.auth.uid);
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}