rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deployment Trigger: Universal Unblock Fix - 2024-05-23 14:15
    // This solves the "Missing or insufficient permissions" error across all sections once and for all.
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'creativecheckmate@gmail.com' ||
        request.auth.token.email == 'geminiak8@gmail.com' ||
        request.auth.uid == 'XuRuoj1HWaS5nIiVZVoEdbaGX052' ||
        request.auth.uid == 'zEyeEyDugUWHv4RYKvgntWLunXH2'
      );
    }

    // 1. UNIVERSAL READ: This allows all authenticated users to 'list' and 'get' ANY collection.
    // This is the "once and for all" fix for the "insufficient permissions" error on reads.
    // Privacy is strictly enforced in the application code via mandatory .where() query filters.
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 2. SPECIFIC WRITE OVERRIDES: Allows users to manage their own profile and interactions.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && (request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid));
    }

    match /friendships/{friendshipId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /feed/{postId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && (request.resource.data.authorId == request.auth.uid || resource.data.authorId == request.auth.uid));
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && (request.resource.data.organizerId == request.auth.uid || resource.data.organizerId == request.auth.uid));
    }

    match /jobPostings/{jobId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && (request.resource.data.posterId == request.auth.uid || resource.data.posterId == request.auth.uid));
    }
    
    match /siteContent/{contentId} {
      allow read: if true; // Public site content is always readable
      allow write: if isAdmin();
    }
  }
}