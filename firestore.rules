rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['creativecheckmate@gmail.com', 'geminiak8@gmail.com'] ||
        request.auth.uid in ['XuRuoj1HWaS5nIiVZVoEdbaGX052', 'zEyeEyDugUWHv4RYKvgntWLunXH2']
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /friendships/{friendshipId} {
      // Broad read allowed for signed-in users to enable collection listing with filters
      // Privacy is strictly enforced by query filters in the application code
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.uids));
    }

    match /notifications/{notificationId} {
      // Broad read allowed for signed-in users to enable collection listing with filters
      // Privacy is strictly enforced by query filters in the application code
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /messages/{messageId} {
      // Participants-only read/write
      allow read: if isSignedIn() && (isAdmin() || (request.auth.uid in resource.data.participants));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.participants));
      allow delete: if isAdmin();
    }

    match /feed/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    match /jobPostings/{jobId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.posterId == request.auth.uid);
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}