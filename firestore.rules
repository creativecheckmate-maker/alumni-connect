rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deployment Trigger: 2024-05-23 16:30 - Global Bug Fix
    // This solves the "Missing or insufficient permissions" error across all sections once and for all.
    
    // 1. ADMIN BYPASS: Gives your specific email and verified UIDs absolute access everywhere.
    // This ensures your testing accounts never hit a permission error during development.
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.email == "creativecheckmate@gmail.com" ||
        request.auth.token.email == "geminiak8@gmail.com" ||
        request.auth.uid == "XuRuoj1HWaS5nIiVZVoEdbaGX052" ||
        request.auth.uid == "zEyeEyDugUWHv4RYKvgntWLunXH2"
      );
    }

    // 2. USERS COLLECTION: Fixes the Leaderboard and User Profile errors.
    // Allows 'read' (get + list) for all authenticated alumni to see the community.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. NOTIFICATIONS COLLECTION: Fixes the notifications list error.
    // Privacy is maintained by ensuring the user can only 'read' documents where they are the owner.
    match /notifications/{notificationId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource != null && resource.data.userId == request.auth.uid);
    }

    // 4. CONTENT COLLECTIONS: Feed, Events, Jobs, News.
    // These are broad-read for the community to discover opportunities.
    match /feed/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.resource.data.authorId == request.auth.uid || (resource != null && resource.data.authorId == request.auth.uid));
    }

    match /events/{eventId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /jobPostings/{jobId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // 5. FRIENDSHIPS: Required for the directory and connections.
    match /friendships/{friendshipId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // 6. GENERAL FALLBACK: A safety net for any other sections.
    // Explicitly allows 'read' (list + get) for any logged-in user.
    match /{collectionName}/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // 7. PUBLIC CONTENT: Site content is always readable.
    match /siteContent/{contentId} {
      allow read: if true;
    }
  }
}