rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deployment Trigger: 2024-05-23 17:45 - Universal Platform Unblock
    // This allows ANY logged-in user to perform 'list' and 'get' operations on ALL collections.
    // This specifically solves the "Missing or insufficient permissions" errors appearing everywhere.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 1. ADMIN BYPASS: Gives your specific email absolute access everywhere.
    // This ensures your testing accounts never hit a permission error during development.
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.email == "creativecheckmate@gmail.com" ||
        request.auth.token.email == "geminiak8@gmail.com" ||
        request.auth.uid == "XuRuoj1HWaS5nIiVZVoEdbaGX052" ||
        request.auth.uid == "zEyeEyDugUWHv4RYKvgntWLunXH2"
      );
    }
  }
}