rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'creativecheckmate@gmail.com' ||
        request.auth.uid == 'XuRuoj1HWaS5nIiVZVoEdbaGX052'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users Collection - Publicly viewable, Owner/Admin writable
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // Messages Collection - Private to participants
    match /messages/{messageId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.senderId == request.auth.uid);
    }

    // Notifications Collection - Private to user
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // Community Feed - Publicly viewable, Authenticated writable
    match /feed/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    // Events - Publicly viewable, Authenticated/Admin writable
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    // Job Postings - Publicly viewable, Authenticated/Admin writable
    match /jobPostings/{jobPostingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.posterId == request.auth.uid);
    }

    // Site Content (CMS) - Publicly viewable, Admin writable
    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}