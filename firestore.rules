
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'creativecheckmate@gmail.com' ||
        request.auth.uid == 'XuRuoj1HWaS5nIiVZVoEdbaGX052'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users Collection - Publicly viewable for directory features
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // Friendships Collection
    match /friendships/{friendshipId} {
      allow list: if isSignedIn() && request.auth.uid in resource.data.uids;
      allow get: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.uids);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.uids;
    }

    // Messages Collection - Split list/get to resolve permission optimization errors
    match /messages/{messageId} {
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow get: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.senderId == request.auth.uid);
    }

    // Notifications Collection - Split list/get to resolve permission optimization errors
    match /notifications/{notificationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Public community content
    match /feed/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
