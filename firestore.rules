rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. ADMIN BYPASS: Gives your specific email and UIDs absolute access everywhere.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "creativecheckmate@gmail.com" ||
        request.auth.token.email == "geminiak8@gmail.com" ||
        request.auth.uid == "XuRuoj1HWaS5nIiVZVoEdbaGX052" ||
        request.auth.uid == "zEyeEyDugUWHv4RYKvgntWLunXH2"
      );
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 2. USERS: Allows authenticated 'list' and 'get' for Directory and Leaderboard.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == userId);
    }

    // 3. NOTIFICATIONS: Restricted to recipient or admin.
    match /notifications/{notificationId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // 4. FRIENDSHIPS: Secure connection tracking.
    match /friendships/{friendshipId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // 5. MESSAGES: Private one-on-one chat with delivery tracking.
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource == null || resource.data.receiverId == request.auth.uid);
    }

    // 6. GENERAL COLLECTIONS: Safety net for feed, jobs, etc.
    match /{collectionName}/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Deployment Trigger: 2024-05-21T17:00:00Z - Applied Universal Security Fix and chatId-based messaging.
  }
}