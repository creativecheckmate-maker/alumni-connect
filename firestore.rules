rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. ADMIN BYPASS: Gives your specific email and UIDs absolute access everywhere.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "creativecheckmate@gmail.com" ||
        request.auth.token.email == "geminiak8@gmail.com" ||
        request.auth.uid == "XuRuoj1HWaS5nIiVZVoEdbaGX052" ||
        request.auth.uid == "zEyeEyDugUWHv4RYKvgntWLunXH2"
      );
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 2. USERS: Allows authenticated 'list' and 'get' for Directory and Leaderboard.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == userId);
    }

    // 3. NOTIFICATIONS: Restricted to recipient or admin.
    match /notifications/{notificationId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // 4. FRIENDSHIPS: Secure connection tracking.
    match /friendships/{friendshipId} {
      allow read: if request.auth != null && (resource == null || request.auth.uid in resource.data.uids);
      allow write: if request.auth != null;
    }

    // 5. MESSAGES: Private one-on-one chat.
    match /messages/{messageId} {
      allow read: if request.auth != null && (resource == null || resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if request.auth != null;
    }

    // 6. SOCIAL FEED: Community updates.
    match /feed/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource == null || resource.data.authorId == request.auth.uid);
    }

    // 7. CAREERS: Job board access.
    match /jobPostings/{jobId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource == null || resource.data.posterId == request.auth.uid);
    }

    // 8. INFRASTRUCTURE: Public content.
    match /siteContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /events/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Deployment Trigger: 2024-05-21T10:00:00Z - Fixed list permissions everywhere.
  }
}
