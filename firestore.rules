rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'creativecheckmate@gmail.com' ||
        request.auth.uid == 'XuRuoj1HWaS5nIiVZVoEdbaGX052'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /friendships/{friendshipId} {
      // Allow participants to manage their connections
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Allow update and delete if user is a participant (check both ID and Data for robustness)
      allow update, delete: if isSignedIn() && (
        request.auth.uid in resource.data.uids || 
        friendshipId.contains(request.auth.uid) || 
        isAdmin()
      );
    }

    match /messages/{messageId} {
      // Allow participants to read and manage their secure chats
      // Granting list permissions for filtered queries
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || messageId.contains(request.auth.uid) || isAdmin());
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update, delete: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.participants || messageId.contains(request.auth.uid)));
    }

    match /notifications/{notificationId} {
      // Users can manage their own activity logs
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /feed/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    match /jobPostings/{jobId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.posterId == request.auth.uid);
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}