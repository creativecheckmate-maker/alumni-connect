rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'XuRuoj1HWaS5nIiVZVoEdbaGX052' ||
        request.auth.token.email == 'creativecheckmate@gmail.com'
      );
    }

    // Users Collection - Allow public listing but private updates
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // Friendships Collection - Filtered by participants
    match /friendships/{friendshipId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Messages Collection - Filtered by participants
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
    }

    // Notifications Collection - Filtered by userId
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Community Content (Public Read)
    match /feed/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    match /jobPostings/{jobId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.posterId == request.auth.uid);
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}