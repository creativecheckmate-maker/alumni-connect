
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'XuRuoj1HWaS5nIiVZVoEdbaGX052' ||
        request.auth.token.email == 'creativecheckmate@gmail.com'
      );
    }

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // Friendships Collection
    match /friendships/{friendshipId} {
      allow get: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.uids);
      allow list: if isSignedIn() && (request.auth.uid in resource.data.uids || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.uids);
      allow delete: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.uids);
    }

    // Messages Collection
    match /messages/{messageId} {
      allow get: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.senderId == request.auth.uid);
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Community Content (Public Read)
    match /feed/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    match /jobPostings/{jobId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.posterId == request.auth.uid);
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
